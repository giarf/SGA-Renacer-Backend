meta {
  name: Get Egresos
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/egresos
  body: none
  auth: none
}

tests {
  test("Status code is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("Response is array", function() {
    expect(res.body).to.be.an("array");
  });

  test("First item has tipoEgreso", function() {
    if (Array.isArray(res.body) && res.body.length > 0) {
      expect(res.body[0]).to.have.property("tipoEgreso");
    }
  });
}
