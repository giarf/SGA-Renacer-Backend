meta {
  name: Create Consumo Interno
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/egresos/consumo-interno
  body: json
  auth: none
}

body:json {
  {
    "egreso": {
      "fecha": "{{todayDate}}",
      "tipoEgreso": "ConsumoInterno",
      "montoValorizadoTotal": 15000
    },
    "consumo": {
      "programaEvento": "Taller de Arte - Test",
      "responsablePersonaId": {{personaId}}
    },
    "detalles": [
      {
        "itemCatalogoId": {{catalogoItemId}},
        "cantidad": 10
      }
    ]
  }
}

script:pre-request {
  const today = new Date().toISOString().split("T")[0];
  bru.setVar("todayDate", today);
}

script:post-response {
  if (res.status === 201 && res.body.id) {
    bru.setVar("egresoConsumoId", res.body.id);
  }
}

tests {
  test("Status code is 201", function() {
    expect(res.status).to.equal(201);
  });

  test("Response has ID", function() {
    expect(res.body.id).to.be.a("number");
  });

  test("Success message is present", function() {
    expect(res.body.mensaje).to.include("Consumo interno");
  });
}
